rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: messages
    // Document ID: auto-generated
    // Fields:
    //   - text: string (required, max 1000) - The message content
    //   - uid: string (required, immutable) - The sender's UID
    //   - createdAt: timestamp (required, immutable) - The message timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "support@mirshid.net" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // Domain Validators
    function isValidMessage(data) {
      return hasRequiredFields(['text', 'uid', 'createdAt']) &&
             validStringLength('text', 1, 1000) &&
             data.uid is string &&
             data.createdAt is timestamp;
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMessage(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
      allow delete: if false;
    }

    match /chats/{chatId} {
      function isChatParticipant() {
        return chatId == 'global' || chatId.matches(".*" + request.auth.uid + ".*");
      }

      match /messages/{messageId} {
        allow read: if isAuthenticated() && isChatParticipant();
        allow create: if isAuthenticated() && isChatParticipant() && isValidMessage(request.resource.data) && request.resource.data.uid == request.auth.uid;
        allow update: if isAuthenticated() && isChatParticipant() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
        allow delete: if false;
      }

      match /typing/{userId} {
        allow read: if isAuthenticated() && isChatParticipant();
        allow write: if isAuthenticated() && isOwner(userId) && isChatParticipant();
      }
    }

    match /typing/{userId} {
      allow read, write: if isAuthenticated();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && hasOnlyAllowedFields(['displayName', 'avatarUrl', 'bio', 'friends']);
    }

    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow create: if isAuthenticated() && request.resource.data.from == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.to);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }

    match /educationalEntities/{entityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
